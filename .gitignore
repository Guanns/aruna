# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production (JANGAN commit build output - mengandung API key embedded)
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - JANGAN PERNAH commit ke git!
.env
.env.example
.env.local
.env.*.local
.env.development
.env.production
.env.test
# .env.example boleh di-commit (berisi template, bukan nilai asli)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Dependencies
/node_modules

# Next.js build output
/.next
/out

# Vercel
.vercel
